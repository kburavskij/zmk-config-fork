FROM zmkfirmware/zmk-build-arm:stable

ARG KEYMAP_DRAWER_VERSION=0.23.0

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --no-cache-dir --break-system-packages "keymap-drawer==${KEYMAP_DRAWER_VERSION}"
